# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: pin model IDs (defaults shown)
MODEL_HUNTER=claude-opus-4-7
MODEL_VALIDATOR=claude-sonnet-4-6
MODEL_RECON=claude-opus-4-7
MODEL_REPORT=claude-sonnet-4-6
MODEL_REFLECT=claude-sonnet-4-6

# --- Email (Gmail IMAP/SMTP recommended; app password) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
MAIL_USER=harness@example.com
MAIL_PASS=app-password-here
# Address commands are accepted from (defense-in-depth allowlist):
OPERATOR_EMAIL=you@example.com

# Cadence of operator-facing reports
REPORT_INTERVAL_MIN=60       # minutes between operator reports
INBOX_POLL_SEC=30            # how often to poll for new commands

# --- GitHub (optional but recommended for self-evolution) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/your-harness-fork   # owner/name; the harness pushes here
GITHUB_BRANCH=autonomous

# --- Harness behavior ---
MAX_CONCURRENT_HUNTERS=8     # set high (e.g. 50) if you have rate limit
SCRATCH_ROOT=./data/scratch
DATA_DIR=./data
TARGETS_DIR=./targets

# Hard kill switch — orchestrator exits if set to 1
KILL_SWITCH=0
