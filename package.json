{
  "name": "mythosharness",
  "version": "0.1.0",
  "description": "Long-running autonomous vulnerability-discovery harness inspired by Cloudflare's Mythos pipeline. Self-modifying, email-driven, GitHub-backed.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "once": "bun run src/index.ts --once",
    "smoke": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@octokit/rest": "^21.0.0",
    "imapflow": "^1.0.171",
    "mailparser": "^3.7.1",
    "nodemailer": "^6.9.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "^6.4.16",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
